<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.expirytracker.app.presentation.splash.SplashFragment"
        android:label="@string/app_name">
        <action android:id="@+id/action_splash_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment android:id="@+id/homeFragment" android:name="com.expirytracker.app.presentation.home.HomeFragment" android:label="@string/app_name">
        <action android:id="@+id/action_home_to_add" app:destination="@id/addProductFragment" />
        <action android:id="@+id/action_home_to_details" app:destination="@id/productDetailsFragment" />
        <action android:id="@+id/action_home_to_settings" app:destination="@id/settingsFragment" />
        <action android:id="@+id/action_home_to_ocr_preview" app:destination="@id/ocrPreviewFragment" />
    </fragment>

    <fragment android:id="@+id/addProductFragment" android:name="com.expirytracker.app.presentation.add.AddProductFragment" android:label="Add Product">
        <argument android:name="productId" app:argType="long" android:defaultValue="0L" />
    </fragment>
    <fragment android:id="@+id/ocrPreviewFragment" android:name="com.expirytracker.app.presentation.ocr.OcrPreviewFragment" android:label="Review Scan">
        <argument android:name="imageUri" app:argType="string" app:nullable="true" android:defaultValue="@null" />
    </fragment>
    <fragment android:id="@+id/productDetailsFragment" android:name="com.expirytracker.app.presentation.details.ProductDetailsFragment" android:label="Product Details">
        <argument android:name="productId" app:argType="long" />
    </fragment>
    <fragment android:id="@+id/settingsFragment" android:name="com.expirytracker.app.presentation.settings.SettingsFragment" android:label="Settings" />
</navigation>
